{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/build-craft-sync.sh" },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/inject-craft-router.sh" },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/inject-craft-incident.sh" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/detect-incident.sh" },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/plan-gate-reset.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/plan-gate-approve.sh" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__Craft__craft_write",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/guard-craft-markdown.sh" },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/guard-plan-gate.sh" }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/guard-plan-hygiene.sh" }
        ]
      }
    ]
  }
}
