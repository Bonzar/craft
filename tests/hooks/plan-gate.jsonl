{"name":"craft_write with no approved plan this turn → deny","hook":"guard-plan-gate","expect":"deny","input":{"tool_name":"mcp__Craft__craft_write","tool_input":{"command":"blocks update --id X --json {taskInfo}"}}}
{"name":"craft_write after ExitPlanMode approval (marker set) → allow","hook":"guard-plan-gate","expect":"allow","setup":["plan-gate-approve"],"input":{"tool_name":"mcp__Craft__craft_write","tool_input":{"command":"blocks update --id X --json {taskInfo}"}}}
{"name":"craft_write after approval then new user message (reset clears marker) → deny","hook":"guard-plan-gate","expect":"deny","setup":["plan-gate-approve","plan-gate-reset"],"input":{"tool_name":"mcp__Craft__craft_write","tool_input":{"command":"blocks update --id X --json {taskInfo}"}}}
{"name":"craft_write under CRAFT_AUTONOMOUS (rutina/eval) → allow (bypass)","hook":"guard-plan-gate","expect":"allow","env":{"CRAFT_AUTONOMOUS":"1"},"input":{"tool_name":"mcp__Craft__craft_write","tool_input":{"command":"blocks update --id X --json {taskInfo}"}}}
{"name":"CRAFT_AUTONOMOUS bypass wins even with marker absent → allow","hook":"guard-plan-gate","expect":"allow","env":{"CRAFT_AUTONOMOUS":"1"},"setup":["plan-gate-reset"],"input":{"tool_name":"mcp__Craft__craft_write","tool_input":{"command":"blocks add --json {type}"}}}
{"name":"non-craft_write tool (Bash) → allow (gate guards only Craft writes)","hook":"guard-plan-gate","expect":"allow","input":{"tool_name":"Bash","tool_input":{"command":"echo hi"}}}
{"name":"craft_read → allow (not a write)","hook":"guard-plan-gate","expect":"allow","input":{"tool_name":"mcp__Craft__craft_read","tool_input":{"command":"blocks get X --depth -1"}}}
